# Database (host ports differ from defaults when using Docker Compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/celery_pipeline
POSTGRES_PORT=5433
REDIS_PORT=6380

# Redis / Celery
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1

# Task defaults
CELERY_TASK_MAX_RETRIES=3
WEBHOOK_TIMEOUT_SECONDS=10
PROCESS_DATA_MAX_DELAY_SECONDS=30
